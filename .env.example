# Core secrets (required for secure startup)
# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=
# API key for OpenAI/OpenRouter calls.
OPENAI_API_KEY=
# Bearer token for protected FastAPI v2 endpoints.
ADMIN_TOKEN=
# Flask session secret and default participant-signing fallback secret.
ADMIN_SECRET_KEY=

# Optional but recommended secret override for participant link signing.
PARTICIPANT_SECRET=
# Optional admin password for non-interactive deployments.
ADMIN_PASSWORD=

# --- База данных (рекомендуется PostgreSQL) ---
# Вариант A — одна строка:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
#
# Вариант B — переменные (удобно в Docker / секретах). Если они заданы, они ПЕРЕКРЫВАЮТ sqlite ниже.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=nopolicybot
POSTGRES_USER=nopolicybot
POSTGRES_PASSWORD=change_me
POSTGRES_DRIVER=asyncpg
# Дубли libpq (если так заведено в системе): PGHOST PGPORT PGDATABASE PGUSER PGPASSWORD
# Хост можно не указывать: при заданных POSTGRES_DB + POSTGRES_USER подставится 127.0.0.1
#
# Локальная разработка без Postgres — оставьте sqlite ниже и очистите POSTGRES_DB / POSTGRES_USER (или весь блок POSTGRES_*).
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# Storage: json | dual | db_first | db_only (алиасы: hybrid→dual, db→db_only)
# После миграции в БД обычно db_only; dual — только на переходный период.
STORAGE_MODE=db_only
PARITY_CHECK_INTERVAL_SEC=300
MESSAGE_RETENTION_DAYS=90
RETENTION_CHECK_INTERVAL_SEC=21600
USER_HASH_SALT=

# API runtime (на VPS 1–2 GB: API_WORKERS=1 и LOW_MEMORY_SERVER=1)
API_PORT=8001
API_WORKERS=1
API_WORKERS_MAX=4
LOW_MEMORY_SERVER=
API_LOG_LEVEL=info
API_RELOAD=false

# Пул async SQLAlchemy для PostgreSQL (опционально, меньше — меньше RAM)
# DB_POOL_SIZE=3
# DB_MAX_OVERFLOW=5
ALLOWED_ORIGINS=https://admin.example.com,https://staging-admin.example.com

# Optional model settings
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=deepseek-chat
# AI_PREFER_FREE=1 или AI_USE_GEMINI_FIRST=1 — использовать Gemini вместо OpenRouter (бесплатно).
# При GEMINI_API_KEY и без OPENAI_API_KEY — Gemini включается автоматически.
AI_PREFER_FREE=
AI_USE_GEMINI_FIRST=1
# GEMINI_MODEL — модель для прямого Gemini API (по умолчанию gemini-2.0-flash)
GEMINI_MODEL=

# Image generation API keys (at least one needed for portrait generation)
# HuggingFace — FLUX.1-schnell/dev, SDXL (~100-200 req/day free)
HF_TOKEN=
# Google AI Studio — Gemini Image (~500 req/day free)
GEMINI_API_KEY=
# Replicate — FLUX (~50/month free)
REPLICATE_API_TOKEN=

# --- Доп. переменные (см. полный список в docs/ENV_VARIABLES.md) ---
# SECRETS_VALIDATE=0 — отключить проверку секретов при старте (не для прода)
# POSTGRES_HOST= POSTGRES_PORT=5432 POSTGRES_DB= POSTGRES_USER= POSTGRES_PASSWORD=
# POSTGRES_DRIVER=asyncpg — если DATABASE_URL пустой, URL соберётся в config/database_url.py
# STORAGE_PRIMARY= — синоним STORAGE_MODE
# API_RATE_LIMIT_PER_MIN=240 API_MAX_URL_LENGTH=2400 API_MAX_BODY_BYTES=1048576
# FLASK_RATE_LIMIT_PER_MIN=300 FLASK_MAX_URL_LENGTH=2600 FLASK_MAX_BODY_BYTES=1048576
# ADMIN_HOST=127.0.0.1 ADMIN_PORT=5000
# PARTICIPANT_BASE_URL= ADMIN_BASE_URL= — база для ссылок участника
# REDIS_URL= — realtime / WS через Redis; WS_REDIS_CHANNEL_PREFIX=nopolicybot:ws
# OPENAI_VISION_MODELS= OPENAI_VISION_MODEL= OPENAI_REPLY_MODELS= OPENAI_FACTCHECK_MODEL=
# AI_USE_OPENROUTER_FIRST=1 AI_PREFER_FREE=1 AI_USE_GEMINI_FIRST=1
# AI_FAST_CACHE_TTL_SEC=45 AI_FAST_CACHE_MAX_ITEMS=512
# PERSONALITY_ENSEMBLE_MODELS=
# GOOGLE_API_KEY= — альтернатива GEMINI_API_KEY
# HUGGINGFACE_TOKEN= — альтернатива HF_TOKEN
# SLO_AUTH_TOKEN= — скрипт check_slo_gate.py
